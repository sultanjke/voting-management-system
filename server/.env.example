NODE_ENV=development
# Set to your Vercel app domain in production (e.g. https://your-app.vercel.app)
CLIENT_ORIGIN=http://localhost:3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/resident_vote?schema=public
SESSION_SECRET=replace-with-a-random-32-plus-char-secret
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=Resident Vote
# Comma-separated allowed origins for WebAuthn (no trailing slash)
WEBAUTHN_ORIGINS=http://localhost:3000

# Optional translation integration
OPENAI_API_KEY=
OPENAI_TRANSLATION_MODEL=gpt-4.1-mini

# Admin bootstrap (used by seed)
ADMIN_BOOTSTRAP_EMAIL=admin
ADMIN_BOOTSTRAP_PASSWORD=ChangeMe123!
