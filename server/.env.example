NODE_ENV=development
# Set to your Vercel app domain in production (e.g. https://your-app.vercel.app)
CLIENT_ORIGIN=http://localhost:3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/resident_vote?schema=public
SESSION_SECRET=replace-with-a-random-32-plus-char-secret

# OTP provider in production: twilio_whatsapp | twilio | vonage
OTP_SMS_PROVIDER=twilio_whatsapp

# Twilio (used when OTP_SMS_PROVIDER=twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_MESSAGING_SERVICE_SID=

# Twilio WhatsApp (used when OTP_SMS_PROVIDER=twilio_whatsapp)
# Example sandbox sender: whatsapp:+14155238886
TWILIO_WHATSAPP_FROM_NUMBER=

# Vonage (used when OTP_SMS_PROVIDER=vonage)
VONAGE_API_KEY=
VONAGE_API_SECRET=
VONAGE_FROM_NUMBER=

# Optional translation integration
OPENAI_API_KEY=
OPENAI_TRANSLATION_MODEL=gpt-4.1-mini

# Admin bootstrap (used by seed)
ADMIN_BOOTSTRAP_EMAIL=admin
ADMIN_BOOTSTRAP_PASSWORD=ChangeMe123!
